<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% block title %}SmartTrip{% endblock %}</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <style>
    :root {
      --navy:   #0d1b2a;
      --navy-2: #112236;
      --gold:   #c9a84c;
      --gold-l: #e8c97a;
      --cream:  #f5f0e8;
      --white:  #ffffff;
      --muted:  #7a8a99;
      --shadow: 0 8px 32px rgba(13,27,42,0.18);
    }
    * { margin:0; padding:0; box-sizing:border-box; }
    html { scroll-behavior:smooth; }
    body { font-family:'Plus Jakarta Sans',sans-serif; background:var(--cream); color:var(--navy); overflow-x:hidden; }

    /* ── NAV ── */
    nav {
      position:fixed; top:0; width:100%; z-index:1000;
      display:flex; align-items:center; justify-content:space-between;
      padding:1.1rem 5%;
      background:rgba(13,27,42,0.96);
      backdrop-filter:blur(20px);
      border-bottom:1px solid rgba(201,168,76,0.2);
      transition:all .3s;
    }
    .nav-logo { font-family:'Playfair Display',serif; font-size:1.5rem; font-weight:700; color:var(--gold); text-decoration:none; letter-spacing:1px; }
    .nav-logo span { color:var(--white); }
    .nav-links { display:flex; gap:2rem; list-style:none; }
    .nav-links a { color:rgba(255,255,255,0.7); text-decoration:none; font-size:.875rem; font-weight:500; transition:color .3s; position:relative; }
    .nav-links a::after { content:''; position:absolute; bottom:-4px; left:0; width:0; height:1px; background:var(--gold); transition:width .3s; }
    .nav-links a:hover { color:var(--gold); }
    .nav-links a:hover::after { width:100%; }
    .nav-cta { background:linear-gradient(135deg,var(--gold),var(--gold-l)); color:var(--navy) !important; padding:.55rem 1.4rem; border-radius:50px; font-weight:700 !important; }
    .nav-cta::after { display:none !important; }

    /* ── FLASH ── */
    .flash { padding:1rem 5%; margin-top:72px; font-size:.875rem; }
    .flash-success { background:rgba(74,222,128,.1); border-left:3px solid #4ade80; color:#166534; }
    .flash-error   { background:rgba(248,113,113,.1); border-left:3px solid #f87171; color:#991b1b; }

    /* ── HERO ── */
    .hero { min-height:100vh; position:relative; display:flex; align-items:center; overflow:hidden; }
    .hero-bg { position:absolute; inset:0; background:url('https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=1920&q=80') center/cover no-repeat; }
    .hero-overlay { position:absolute; inset:0; background:linear-gradient(135deg,rgba(13,27,42,0.95) 0%,rgba(13,27,42,0.65) 50%,rgba(13,27,42,0.4) 100%); }
    .hero-content { position:relative; z-index:2; padding:0 5%; max-width:720px; }
    .hero-badge { display:inline-flex; align-items:center; gap:.5rem; background:rgba(201,168,76,0.15); border:1px solid rgba(201,168,76,0.35); color:var(--gold); padding:.4rem 1rem; border-radius:50px; font-size:.75rem; font-weight:600; letter-spacing:1.5px; text-transform:uppercase; margin-bottom:1.5rem; }
    .hero h1 { font-family:'Playfair Display',serif; font-size:clamp(2.5rem,6vw,5rem); line-height:1.1; margin-bottom:1.5rem; color:var(--white); }
    .hero h1 em { font-style:italic; color:var(--gold); }
    .hero p { font-size:1.05rem; color:rgba(255,255,255,0.7); line-height:1.75; margin-bottom:2.5rem; max-width:500px; }
    .hero-btns { display:flex; gap:1rem; flex-wrap:wrap; }
    .hero-search { position:absolute; bottom:2.5rem; left:5%; right:5%; z-index:2; }
    .search-box { background:rgba(13,27,42,0.92); border:1px solid rgba(201,168,76,0.25); border-radius:16px; padding:1.4rem 2rem; display:flex; gap:1rem; align-items:center; flex-wrap:wrap; backdrop-filter:blur(20px); }
    .search-field { flex:1; min-width:140px; display:flex; flex-direction:column; gap:.25rem; }
    .search-field label { font-size:.65rem; text-transform:uppercase; letter-spacing:1.2px; color:var(--gold); font-weight:700; }
    .search-field input, .search-field select { background:transparent; border:none; outline:none; color:var(--white); font-size:.9rem; font-family:'Plus Jakarta Sans',sans-serif; cursor:pointer; }
    .search-field select option { background:var(--navy); }
    .search-divider { width:1px; height:36px; background:rgba(201,168,76,0.2); }
    .search-btn { background:linear-gradient(135deg,var(--gold),var(--gold-l)); color:var(--navy); border:none; cursor:pointer; padding:.85rem 1.6rem; border-radius:10px; font-weight:700; font-size:.875rem; display:flex; align-items:center; gap:.5rem; transition:transform .3s,box-shadow .3s; white-space:nowrap; }
    .search-btn:hover { transform:translateY(-2px); box-shadow:0 8px 25px rgba(201,168,76,0.4); }

    /* ── BUTTONS ── */
    .btn-primary { background:linear-gradient(135deg,var(--gold),var(--gold-l)); color:var(--navy); padding:.85rem 2rem; border-radius:50px; font-weight:700; font-size:.9rem; text-decoration:none; display:inline-flex; align-items:center; gap:.5rem; transition:transform .3s,box-shadow .3s; }
    .btn-primary:hover { transform:translateY(-3px); box-shadow:0 12px 35px rgba(201,168,76,0.4); }
    .btn-outline-light { border:1px solid rgba(255,255,255,0.35); color:var(--white); padding:.85rem 2rem; border-radius:50px; font-weight:500; font-size:.9rem; text-decoration:none; display:inline-flex; align-items:center; gap:.5rem; backdrop-filter:blur(10px); transition:border-color .3s,background .3s; }
    .btn-outline-light:hover { border-color:var(--gold); background:rgba(201,168,76,0.1); color:var(--gold); }
    .btn-gold { background:linear-gradient(135deg,var(--gold),var(--gold-l)); color:var(--navy); border:none; cursor:pointer; padding:.6rem 1.4rem; border-radius:50px; font-weight:700; font-size:.85rem; text-decoration:none; display:inline-flex; align-items:center; gap:.4rem; transition:transform .3s,box-shadow .3s; }
    .btn-gold:hover { transform:translateY(-2px); box-shadow:0 8px 20px rgba(201,168,76,0.4); }
    .btn-navy { background:var(--navy); color:var(--gold); border:1px solid rgba(201,168,76,0.3); padding:.6rem 1.4rem; border-radius:50px; font-weight:600; font-size:.85rem; text-decoration:none; display:inline-flex; align-items:center; gap:.4rem; transition:all .3s; }
    .btn-navy:hover { background:var(--gold); color:var(--navy); }
    .btn-danger-sm { background:rgba(220,38,38,0.1); color:#dc2626; border:1px solid rgba(220,38,38,0.2); padding:.4rem .9rem; border-radius:8px; cursor:pointer; font-size:.78rem; font-weight:600; text-decoration:none; display:inline-flex; align-items:center; gap:.3rem; transition:all .3s; }
    .btn-danger-sm:hover { background:rgba(220,38,38,0.2); }

    .btn-ai-nav {
      background: rgba(201,168,76,0.1);
      color: var(--gold);
      border: 1px solid var(--gold);
      padding: .5rem 1.2rem;
      border-radius: 50px;
      font-weight: 700;
      font-size: .85rem;
      text-decoration: none;
      transition: all 0.3s;
      display: flex;
      align-items: center;
      gap: .5rem;
    }
    .btn-ai-nav:hover {
      background: var(--gold);
      color: var(--navy);
      box-shadow: 0 4px 15px rgba(201,168,76,0.3);
    }

    /* ── SECTIONS ── */
    section { padding:5rem 5%; }
    .section-label { display:inline-block; color:var(--gold); font-size:.72rem; font-weight:700; letter-spacing:2.5px; text-transform:uppercase; margin-bottom:.75rem; }
    .section-title { font-family:'Playfair Display',serif; font-size:clamp(1.8rem,3.5vw,2.8rem); color:var(--navy); line-height:1.2; margin-bottom:.75rem; }
    .section-title.light { color:var(--white); }
    .section-sub { color:var(--muted); font-size:.95rem; line-height:1.75; max-width:480px; }
    .section-header { display:flex; justify-content:space-between; align-items:flex-end; margin-bottom:2.5rem; flex-wrap:wrap; gap:1rem; }

    /* ── DESTINATIONS GRID ── */
    #destinations { background:var(--cream); }
    .dest-grid { display:grid; grid-template-columns:repeat(3,1fr); grid-template-rows:auto auto; gap:1.2rem; }
    .dest-card { position:relative; border-radius:14px; overflow:hidden; cursor:pointer; }
    .dest-card-featured { grid-row:1/3; }
    .dest-card img { width:100%; height:100%; min-height:220px; object-fit:cover; transition:transform .6s; }
    .dest-card-featured img { min-height:480px; }
    .dest-card:hover img { transform:scale(1.07); }
    .dest-overlay { position:absolute; inset:0; background:linear-gradient(to top,rgba(13,27,42,0.92) 0%,transparent 55%); display:flex; flex-direction:column; justify-content:flex-end; padding:1.6rem; }
    .dest-badge { background:rgba(201,168,76,0.92); color:var(--navy); font-size:.65rem; font-weight:700; padding:.2rem .6rem; border-radius:50px; display:inline-block; margin-bottom:.6rem; width:fit-content; letter-spacing:.5px; text-transform:uppercase; }
    .dest-name { font-family:'Playfair Display',serif; font-size:1.3rem; color:var(--white); margin-bottom:.25rem; }
    .dest-card-featured .dest-name { font-size:1.7rem; }
    .dest-info { display:flex; justify-content:space-between; align-items:center; }
    .dest-price { color:var(--gold); font-weight:700; font-size:.95rem; }
    .dest-action { width:34px; height:34px; background:var(--gold); border-radius:50%; display:flex; align-items:center; justify-content:center; color:var(--navy); font-size:.75rem; opacity:0; transform:translateY(8px); transition:opacity .3s,transform .3s; text-decoration:none; }
    .dest-card:hover .dest-action { opacity:1; transform:translateY(0); }

    /* ── PACKAGES ── */
    #packages { background:var(--navy); }
    .packages-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:1.4rem; margin-top:2.5rem; }
    .pkg-card { background:var(--navy-2); border:1px solid rgba(201,168,76,0.12); border-radius:14px; overflow:hidden; transition:transform .3s,box-shadow .3s,border-color .3s; position:relative; }
    .pkg-card:hover { transform:translateY(-8px); box-shadow:0 25px 60px rgba(0,0,0,0.4); border-color:rgba(201,168,76,0.35); }
    .pkg-card.featured { border-color:var(--gold); }
    .pkg-ribbon { position:absolute; top:1rem; right:1rem; background:var(--gold); color:var(--navy); font-size:.65rem; font-weight:700; padding:.25rem .75rem; border-radius:50px; z-index:1; letter-spacing:.5px; }
    .pkg-img { height:190px; overflow:hidden; }
    .pkg-img img { width:100%; height:100%; object-fit:cover; transition:transform .5s; }
    .pkg-card:hover .pkg-img img { transform:scale(1.08); }
    .pkg-body { padding:1.4rem; }
    .pkg-meta { display:flex; gap:.8rem; font-size:.75rem; color:rgba(255,255,255,0.5); margin-bottom:.9rem; flex-wrap:wrap; }
    .pkg-meta span { display:flex; align-items:center; gap:.3rem; }
    .pkg-meta i { color:var(--gold); }
    .pkg-name { font-family:'Playfair Display',serif; font-size:1.15rem; color:var(--white); margin-bottom:.4rem; }
    .pkg-desc { color:rgba(255,255,255,0.55); font-size:.82rem; line-height:1.65; margin-bottom:1.1rem; }
    .pkg-features { list-style:none; margin-bottom:1.3rem; }
    .pkg-features li { font-size:.8rem; color:rgba(255,255,255,0.6); display:flex; align-items:center; gap:.45rem; padding:.25rem 0; }
    .pkg-features i { color:var(--gold); font-size:.65rem; }
    .pkg-footer { display:flex; justify-content:space-between; align-items:center; border-top:1px solid rgba(201,168,76,0.12); padding-top:1.1rem; }
    .pkg-price-label { font-size:.7rem; color:rgba(255,255,255,0.45); }
    .pkg-price { font-size:1.4rem; font-weight:700; color:var(--gold); }
    .pkg-price small { font-size:.7rem; color:rgba(255,255,255,0.45); }

    /* ── ABOUT ── */
    #about { background:var(--cream); display:grid; grid-template-columns:1fr 1fr; gap:5rem; align-items:center; }
    .about-img-wrap { position:relative; }
    .about-img-main { width:100%; height:480px; object-fit:cover; border-radius:16px; }
    .about-img-badge { position:absolute; bottom:-1.5rem; right:-1.5rem; background:var(--gold); color:var(--navy); border-radius:14px; padding:1.4rem; text-align:center; box-shadow:0 20px 50px rgba(201,168,76,0.3); }
    .about-img-badge strong { font-size:2.2rem; display:block; line-height:1; font-family:'Playfair Display',serif; }
    .about-img-badge span { font-size:.75rem; font-weight:600; letter-spacing:.5px; }
    .about-features { display:grid; grid-template-columns:1fr 1fr; gap:1rem; margin:1.8rem 0; }
    .about-feat { display:flex; gap:.9rem; align-items:flex-start; background:var(--white); border:1px solid rgba(201,168,76,0.12); padding:1.1rem; border-radius:12px; transition:border-color .3s,box-shadow .3s; }
    .about-feat:hover { border-color:var(--gold); box-shadow:var(--shadow); }
    .about-feat-icon { width:40px; height:40px; background:rgba(201,168,76,0.1); border-radius:10px; display:flex; align-items:center; justify-content:center; color:var(--gold); flex-shrink:0; }
    .about-feat h4 { font-size:.875rem; color:var(--navy); margin-bottom:.25rem; font-weight:600; }
    .about-feat p { font-size:.78rem; color:var(--muted); line-height:1.5; }

    /* ── CONTACT ── */
    #contact { background:var(--navy); display:grid; grid-template-columns:1fr 1.5fr; gap:5rem; align-items:start; }
    .contact-items { display:flex; flex-direction:column; gap:1.4rem; margin-top:2rem; }
    .contact-item { display:flex; gap:1rem; align-items:flex-start; }
    .contact-icon { width:46px; height:46px; background:rgba(201,168,76,0.1); border:1px solid rgba(201,168,76,0.2); border-radius:12px; display:flex; align-items:center; justify-content:center; color:var(--gold); flex-shrink:0; }
    .contact-item h4 { font-size:.78rem; color:rgba(255,255,255,0.5); margin-bottom:.2rem; text-transform:uppercase; letter-spacing:.5px; }
    .contact-item p { color:var(--white); font-size:.9rem; }
    .contact-form { background:rgba(255,255,255,0.04); border:1px solid rgba(201,168,76,0.15); border-radius:18px; padding:2.2rem; }
    .contact-form h3 { font-family:'Playfair Display',serif; margin-bottom:1.4rem; color:var(--white); font-size:1.3rem; }
    .form-row { display:grid; grid-template-columns:1fr 1fr; gap:1rem; }
    .form-group { margin-bottom:1.1rem; }
    .form-group label { display:block; font-size:.72rem; color:rgba(255,255,255,0.55); font-weight:600; letter-spacing:.5px; text-transform:uppercase; margin-bottom:.45rem; }
    .form-group input, .form-group select, .form-group textarea { width:100%; background:rgba(255,255,255,0.06); border:1px solid rgba(201,168,76,0.15); border-radius:10px; padding:.75rem 1rem; color:var(--white); font-family:'Plus Jakarta Sans',sans-serif; font-size:.875rem; outline:none; transition:border-color .3s; }
    .form-group input:focus, .form-group select:focus, .form-group textarea:focus { border-color:var(--gold); }
    .form-group textarea { resize:vertical; min-height:100px; }
    .form-group select option { background:var(--navy); }
    .btn-submit { width:100%; background:linear-gradient(135deg,var(--gold),var(--gold-l)); color:var(--navy); border:none; cursor:pointer; padding:.95rem; border-radius:10px; font-weight:700; font-size:.95rem; font-family:'Plus Jakarta Sans',sans-serif; display:flex; align-items:center; justify-content:center; gap:.5rem; transition:transform .3s,box-shadow .3s; }
    .btn-submit:hover { transform:translateY(-2px); box-shadow:0 12px 30px rgba(201,168,76,0.4); }

    /* ── FOOTER ── */
    footer { background:#07101a; border-top:1px solid rgba(201,168,76,0.1); padding:3.5rem 5% 2rem; }
    .footer-grid { display:grid; grid-template-columns:1.5fr 1fr 1fr 1fr; gap:3rem; margin-bottom:2.5rem; }
    .footer-brand p { color:rgba(255,255,255,0.45); font-size:.82rem; line-height:1.7; margin:1rem 0 1.3rem; }
    .social-links { display:flex; gap:.7rem; }
    .social-link { width:36px; height:36px; background:rgba(201,168,76,0.1); border:1px solid rgba(201,168,76,0.2); border-radius:50%; display:flex; align-items:center; justify-content:center; color:var(--gold); font-size:.8rem; text-decoration:none; transition:background .3s,transform .3s; }
    .social-link:hover { background:var(--gold); color:var(--navy); transform:translateY(-3px); }
    .footer-col h4 { font-size:.82rem; font-weight:700; color:var(--white); margin-bottom:1rem; letter-spacing:.5px; text-transform:uppercase; }
    .footer-col ul { list-style:none; }
    .footer-col ul li { margin-bottom:.55rem; }
    .footer-col ul a { color:rgba(255,255,255,0.45); text-decoration:none; font-size:.82rem; transition:color .3s; display:flex; align-items:center; gap:.35rem; }
    .footer-col ul a:hover { color:var(--gold); }
    .footer-bottom { border-top:1px solid rgba(201,168,76,0.1); padding-top:1.4rem; display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:1rem; }
    .footer-bottom p { color:rgba(255,255,255,0.35); font-size:.78rem; }
    .footer-bottom span { color:var(--gold); }

    /* ── RESPONSIVE ── */
    @media(max-width:1024px) {
      .dest-grid { grid-template-columns:1fr 1fr; }
      .dest-card-featured { grid-row:auto; }
      .packages-grid { grid-template-columns:1fr 1fr; }
      #about,#contact { grid-template-columns:1fr; gap:3rem; }
      .footer-grid { grid-template-columns:1fr 1fr; }
    }
    @media(max-width:768px) {
      .nav-links { display:none; }
      .dest-grid,.packages-grid { grid-template-columns:1fr; }
      .search-box { flex-direction:column; }
      .search-divider { display:none; }
      .about-features,.form-row { grid-template-columns:1fr; }
      .footer-grid { grid-template-columns:1fr; gap:2rem; }
      .about-img-badge { right:1rem; bottom:1rem; }
    }

    @keyframes fadeInUp { from{opacity:0;transform:translateY(28px)} to{opacity:1;transform:translateY(0)} }
    .fade-in { animation:fadeInUp .8s ease forwards; }
    .delay-1 { animation-delay:.2s; opacity:0; }
    .delay-2 { animation-delay:.4s; opacity:0; }
  </style>
  {% block stylesheets %}{% endblock %}
</head>
<body>

<!-- NAVBAR -->
<nav id="navbar">
  <a href="{{ path('app_home') }}" class="nav-logo">Voyage<span>Elite</span></a>
  <ul class="nav-links">
    <li><a href="{{ path('destination_index') }}">Destinations</a></li>
    <li><a href="{{ path('voyage_index') }}">Voyages</a></li>
    <li><a href="{{ path('transport_index') }}">Transports</a></li>
    <li><a href="{{ path('user_paiement_index') }}">Mes Paiements</a></li>
    <li><a href="{{ path('admin_transport_index') }}" style="color:var(--gold); font-weight:700;"><i class="fas fa-shield-alt"></i> Administration</a></li>
    <li><a href="{{ path('app_home') }}#about">À propos</a></li>
    <li><a href="{{ path('app_home') }}#contact" class="nav-cta">Réserver</a></li>
  </ul>
</nav>

<!-- FLASH MESSAGES -->
{% for msg in app.flashes('success') %}
  <div class="flash flash-success">✅ {{ msg }}</div>
{% endfor %}
{% for msg in app.flashes('error') %}
  <div class="flash flash-error">❌ {{ msg }}</div>
{% endfor %}

{% block body %}{% endblock %}

<!-- FOOTER -->
<footer>
  <div class="footer-grid">
    <div class="footer-brand">
      <a href="{{ path('app_home') }}" class="nav-logo" style="font-size:1.3rem">Voyage<span style="color:#fff">Elite</span></a>
      <p>Votre partenaire de confiance pour des voyages d'exception. Nous créons des expériences inoubliables à travers le monde entier.</p>
      <div class="social-links">
        <a href="#" class="social-link"><i class="fab fa-facebook-f"></i></a>
        <a href="#" class="social-link"><i class="fab fa-instagram"></i></a>
        <a href="#" class="social-link"><i class="fab fa-twitter"></i></a>
        <a href="#" class="social-link"><i class="fab fa-youtube"></i></a>
      </div>
    </div>
    <div class="footer-col">
      <h4>Destinations</h4>
      <ul>
        <li><a href="{{ path('destination_index') }}"><i class="fas fa-chevron-right" style="font-size:.6rem"></i> Toutes les destinations</a></li>
        <li><a href="{{ path('destination_new') }}"><i class="fas fa-chevron-right" style="font-size:.6rem"></i> Ajouter une destination</a></li>
      </ul>
    </div>
    <div class="footer-col">
      <h4>Voyages</h4>
      <ul>
        <li><a href="{{ path('voyage_index') }}"><i class="fas fa-chevron-right" style="font-size:.6rem"></i> Tous les voyages</a></li>
        <li><a href="{{ path('voyage_new') }}"><i class="fas fa-chevron-right" style="font-size:.6rem"></i> Créer un voyage</a></li>
      </ul>
    </div>
    <div class="footer-col">
      <h4>Transports</h4>
      <ul>
        <li><a href="{{ path('transport_index') }}"><i class="fas fa-chevron-right" style="font-size:.6rem"></i> Réserver un transport</a></li>
        <li><a href="{{ path('user_paiement_index') }}"><i class="fas fa-chevron-right" style="font-size:.6rem"></i> Mes Paiements</a></li>
        <li><a href="{{ path('admin_paiement_index') }}"><i class="fas fa-chevron-right" style="font-size:.6rem"></i> Gestion Paiements (Admin)</a></li>
        <li><a href="{{ path('admin_transport_index') }}"><i class="fas fa-chevron-right" style="font-size:.6rem"></i> Gestion Transport (Admin)</a></li>
      </ul>
    </div>
    <div class="footer-col">
