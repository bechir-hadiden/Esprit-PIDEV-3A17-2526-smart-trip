{% extends 'base.html.twig' %}

{% block title %}Réservation confirmée - SmartTrip{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .success-container {
            max-width: 600px;
            margin: 50px auto;
        }
        .success-card {
            background: white;
            border-radius: 20px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.1);
            overflow: hidden;
        }
        .success-header {
            background: linear-gradient(135deg, #28a745, #20c997);
            color: white;
            padding: 40px;
            text-align: center;
        }
        .success-header i {
            font-size: 4rem;
            margin-bottom: 15px;
        }
        .success-header h2 {
            margin: 0;
            font-size: 1.8rem;
        }
        .success-body {
            padding: 30px;
        }
        .info-section {
            background: #f8f9fa;
            border-radius: 10px;
            padding: 20px;
            margin-bottom: 20px;
        }
        .info-row {
            display: flex;
            justify-content: space-between;
            padding: 10px 0;
            border-bottom: 1px solid #e9ecef;
        }
        .info-row:last-child {
            border-bottom: none;
        }
        .info-label {
            font-weight: 600;
            color: #495057;
        }
        .info-value {
            color: #28a745;
            font-weight: 500;
        }
        .btn-custom {
            background: linear-gradient(135deg, #667eea, #764ba2);
            color: white;
            padding: 12px 25px;
            border-radius: 10px;
            text-decoration: none;
            display: inline-block;
            transition: all 0.3s;
        }
        .btn-custom:hover {
            transform: translateY(-2px);
            color: white;
            box-shadow: 0 5px 15px rgba(102,126,234,0.4);
        }
        .btn-outline-custom {
            border: 2px solid #667eea;
            color: #667eea;
            padding: 10px 20px;
            border-radius: 10px;
            text-decoration: none;
            display: inline-block;
            transition: all 0.3s;
        }
        .btn-outline-custom:hover {
            background: #667eea;
            color: white;
        }
        .alert-info {
            background: #d1ecf1;
            border: none;
            border-radius: 10px;
            color: #0c5460;
        }
    </style>
{% endblock %}

{% block body %}
<div class="container">
    <div class="success-container">
        <div class="success-card">
            <div class="success-header">
                <i class="fas fa-check-circle"></i>
                <h2>Réservation confirmée !</h2>
                <p class="mb-0">Votre réservation a bien été enregistrée</p>
            </div>
            
            <div class="success-body">
                <div class="alert alert-info">
                    <i class="fas fa-info-circle"></i>
                    Un email de confirmation vous a été envoyé. Votre réservation sera traitée dans les plus brefs délais.
                </div>
                
                <div class="info-section">
                    <h5><i class="fas fa-ticket-alt"></i> Détails de votre réservation</h5>
                    
                    <div class="info-row">
                        <span class="info-label">Numéro de réservation :</span>
                        <span class="info-value">{{ reservation.reservationNumber }}</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Statut :</span>
                        <span class="info-value">
                            <span class="badge bg-warning text-dark">En attente de confirmation</span>
                        </span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Date de réservation :</span>
                        <span class="info-value">{{ reservation.reservationDate|date('d/m/Y H:i') }}</span>
                    </div>
                </div>
                
                <div class="info-section">
                    <h5><i class="fas fa-plane"></i> Détails du vol</h5>
                    
                    <div class="info-row">
                        <span class="info-label">Compagnie :</span>
                        <span class="info-value">{{ reservation.airline }}</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Vol :</span>
                        <span class="info-value">{{ reservation.flightNumber }}</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Destination :</span>
                        <span class="info-value">{{ reservation.destination }}</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Départ :</span>
                        <span class="info-value">{{ reservation.departureAirport }} - {{ reservation.departureTime|date('d/m/Y H:i') }}</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Arrivée :</span>
                        <span class="info-value">{{ reservation.arrivalAirport }} - {{ reservation.arrivalTime|date('d/m/Y H:i') }}</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Nombre de passagers :</span>
                        <span class="info-value">{{ reservation.numberOfPassengers }}</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Prix total :</span>
                        <span class="info-value">{{ reservation.totalPrice|number_format(2) }} €</span>
                    </div>
                </div>
                
                <div class="info-section">
                    <h5><i class="fas fa-user"></i> Informations passager</h5>
                    
                    <div class="info-row">
                        <span class="info-label">Nom :</span>
                        <span class="info-value">{{ reservation.nomClient }}</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Email :</span>
                        <span class="info-value">{{ reservation.email }}</span>
                    </div>
                    {% if reservation.telephone %}
                    <div class="info-row">
                        <span class="info-label">Téléphone :</span>
                        <span class="info-value">{{ reservation.telephone }}</span>
                    </div>
                    {% endif %}
                </div>
                
                <div class="text-center mt-4">
                    <a href="{{ path('app_avis_index') }}" class="btn-custom me-2">
                        <i class="fas fa-star"></i> Donner mon avis
                    </a>
                    <a href="{{ path('app_mes_reservations') }}" class="btn-outline-custom">
                        <i class="fas fa-list"></i> Mes réservations
                    </a>
                </div>
                
                <hr class="my-4">
                
                <div class="text-center">
                    <small class="text-muted">
                        <i class="fas fa-envelope"></i> Un email de confirmation a été envoyé à <strong>{{ reservation.email }}</strong>
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}